<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:GoodsManager.Pages"
             xmlns:models="clr-namespace:GoodsManager.UIModels;assembly=GoodsManager.UIModels"       
             x:Class="GoodsManager.Pages.WarehousesPage"
             Title="Усі склади">
    <CollectionView
        ItemsSource="{Binding Warehouses}"
        Margin="10"
        SelectionMode="Single"
        SelectionChanged="WarehouseSelected">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:WarehouseUIModel">
                <Border
                    Stroke="Magenta"
                    Padding="10"
                    Margin="0,10">
                    <VerticalStackLayout>
                        <Label 
                            Text="{Binding Name}"
                            Style="{StaticResource SubHeadline}" />

                        <Label
                            Text="{Binding Location, Converter={StaticResource EnumToDisplayName}}"
                            HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>