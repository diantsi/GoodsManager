<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:GoodsManager.DTOModels.Warehouses;assembly=GoodsManager.DTOModels"
             xmlns:vm="clr-namespace:GoodsManager.ViewModels"
             xmlns:mct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="GoodsManager.Pages.WarehousesPage"
             x:DataType="vm:WarehousesViewModel"
             Title="Усі склади">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Додати склад" 
                     Command="{Binding AddWarehouseCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, Auto, *">
        
        <SearchBar Grid.Row="0"
                   Placeholder="Пошук складів..."
                   Text="{Binding SearchText}"
                   SearchCommand="{Binding ApplyFilterAndSortCommand}">
            <SearchBar.Behaviors>
                <mct:EventToCommandBehavior EventName="TextChanged" 
                                            Command="{Binding ApplyFilterAndSortCommand}" />
            </SearchBar.Behaviors>
        </SearchBar>

        <HorizontalStackLayout Grid.Row="1" Spacing="10" Padding="10">
            <Label Text="Сортувати за:" VerticalOptions="Center" />
            <Picker ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSortOption}"
                    WidthRequest="150">
                <Picker.Behaviors>
                    <mct:EventToCommandBehavior EventName="SelectedIndexChanged" 
                                                Command="{Binding ApplyFilterAndSortCommand}" />
                </Picker.Behaviors>
            </Picker>
        </HorizontalStackLayout>

        <RefreshView Grid.Row="2"
                     Command="{Binding RefreshDataCommand}">
            <CollectionView ItemsSource="{Binding Warehouses}"
                            Margin="10"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedWarehouse, Mode=TwoWay}"
                            SelectionChangedCommand="{Binding LoadWarehouseCommand}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:WarehouseListDTO">
                        <Border Stroke="Magenta"
                                Padding="15"
                                Margin="0,5">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding Name}"
                                       FontSize="20"
                                       FontAttributes="Bold" />

                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="Місто:" FontAttributes="Bold"/>
                                    <Label Text="{Binding Location}" />
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="Товарів на суму:" />
                                    <Label Text="{Binding TotalValue, StringFormat='{0} грн'}" 
                                           TextColor="#2196F3" 
                                           FontAttributes="Bold"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3"
              BackgroundColor="#80000000"
              IsVisible="{Binding IsBusy}">
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   Color="Magenta"
                                   HeightRequest="50"
                                   WidthRequest="50" />
                <Label Text="Завантаження..."
                       TextColor="White"
                       FontSize="18"
                       FontAttributes="Bold" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
