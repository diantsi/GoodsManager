<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GoodsManager.Pages.GoodCreatePage"
             Title="Створіть новий товар">

    <ScrollView>
        <VerticalStackLayout Padding="10,20" Spacing="10">
            <Label Text="Назва товару" />
            <Entry x:Name="eTitle" Placeholder="Введіть назву" />
            <Label Text="Категорія" />
            <Picker x:Name="pCategory" 
                    Title="Виберіть категорію" />

            <Label Text="Кількість" />
            <Entry x:Name="eQuantity" Keyboard="Numeric" Placeholder="0" />

            <Label Text="Ціна за одиницю (UAH)" />
            <Entry x:Name="ePrice" Keyboard="Numeric" Placeholder="0.00" />

            <Label Text="Опис" />
            <Editor x:Name="eDescription" Placeholder="Додайте опис товару" HeightRequest="100" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Padding="10">
                <Button Grid.Column="0" Text="Зберегти" Clicked="CreateClicked" />
                <Button Grid.Column="1" Text="Назад" Clicked="BackClicked" BackgroundColor="Gray" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>