<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GoodsManager.ViewModels"
             x:Class="GoodsManager.Pages.GoodDetailsPage"
             x:DataType="vm:GoodDetailsViewModel"
             Title="Деталі Товару">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Назва товару:" FontAttributes="Bold" TextColor="Gray" />
            <Label Text="{Binding Title}" Margin="10,0,0,10" FontSize="22" FontAttributes="Bold" />

            <Label Text="Категорія:" FontAttributes="Bold" TextColor="Gray" />
            <Label Text="{Binding ItemCategory}" Margin="10,0,0,10" FontSize="16" />

            <Label Text="Опис:" FontAttributes="Bold" TextColor="Gray" />
            <Label Text="{Binding Description}" Margin="10,0,0,10" FontSize="16" />

            
            <Label Text="Кількість:" FontAttributes="Bold" TextColor="Gray" />
            <Label Text="{Binding Quantity}" Margin="10,0,0,10"  FontSize="16" />

            <Label Text="Ціна за одиницю:" FontAttributes="Bold" TextColor="Gray" />
            <Label Text="{Binding Price, StringFormat='{0} грн'}" Margin="10,0,0,10"  FontSize="18" />

            <Label Text="Загальна вартість товару:" TextColor="Gray" />
            <Label Text="{Binding TotalCost, StringFormat='{0} грн'}" 
                           Margin="10,0,0,10" 
                           FontSize="20" 
                           TextColor="#2196F3" 
                           FontAttributes="Bold" />
                

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>