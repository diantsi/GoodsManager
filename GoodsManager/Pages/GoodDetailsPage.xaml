<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GoodsManager.ViewModels"
             x:Class="GoodsManager.Pages.GoodDetailsPage"
             x:DataType="vm:GoodDetailsViewModel"
             Title="Деталі Товару">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="15">
                
                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,0,0,10">
                    <Button Text="Редагувати" 
                            Command="{Binding EditGoodCommand}" 
                            BackgroundColor="#2196F3" />
                    <Button Text="Видалити" 
                            Command="{Binding DeleteGoodCommand}" 
                            BackgroundColor="Red" />
                </HorizontalStackLayout>

                <Label Text="Назва товару:" FontAttributes="Bold" TextColor="Gray" />
                <Label Text="{Binding CurrentGood.Title}" Margin="10,0,0,10" FontSize="22" FontAttributes="Bold" />

                <Label Text="Категорія:" FontAttributes="Bold" TextColor="Gray" />
                <Label Text="{Binding CurrentGood.ItemCategory}" Margin="10,0,0,10" FontSize="16" />

                <Label Text="Опис:" FontAttributes="Bold" TextColor="Gray" />
                <Label Text="{Binding CurrentGood.Description}" Margin="10,0,0,10" FontSize="16" />

                <Label Text="Кількість:" FontAttributes="Bold" TextColor="Gray" />
                <Label Text="{Binding CurrentGood.Quantity}" Margin="10,0,0,10"  FontSize="16" />

                <Label Text="Ціна за одиницю:" FontAttributes="Bold" TextColor="Gray" />
                <Label Text="{Binding CurrentGood.Price, StringFormat='{0} грн'}" Margin="10,0,0,10"  FontSize="18" />

                <Label Text="Загальна вартість товару:" TextColor="Gray" />
                <Label Text="{Binding CurrentGood.TotalValue, StringFormat='{0} грн'}" 
                               Margin="10,0,0,10" 
                               FontSize="20" 
                               TextColor="#2196F3" 
                               FontAttributes="Bold" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading Overlay -->
        <Grid BackgroundColor="#80000000"
              IsVisible="{Binding IsBusy}">
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   Color="Magenta"
                                   HeightRequest="50"
                                   WidthRequest="50" />
                <Label Text="Завантаження..."
                       TextColor="White"
                       FontSize="18"
                       FontAttributes="Bold" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
