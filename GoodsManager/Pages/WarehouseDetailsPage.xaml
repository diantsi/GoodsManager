<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:GoodsManager.DTOModels.Goods;assembly=GoodsManager.DTOModels"
             xmlns:vm="clr-namespace:GoodsManager.ViewModels"
             xmlns:mct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="GoodsManager.Pages.WarehouseDetailsPage"
             x:DataType="vm:WarehouseDetailsViewModel"
             Title="Деталі Складу">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Додати товар" 
                     Command="{Binding AddGoodCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, *">

        <Border Grid.Row="0"
                Padding="15"
                Margin="10">
            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding CurrentWarehouse.Name}" 
                       FontSize="24" 
                       FontAttributes="Bold" />

                <HorizontalStackLayout Spacing="5">
                    <Label Text="Місто:" FontAttributes="Bold" />
                    <Label Text="{Binding CurrentWarehouse.Location}" />
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="5">
                    <Label Text="Загальна вартість товарів:" FontAttributes="Bold"/>
                    <Label Text="{Binding CurrentWarehouse.TotalValue, StringFormat='{0} грн'}" 
                           TextColor="#2196F3" 
                           FontAttributes="Bold"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

        <HorizontalStackLayout Grid.Row="1" Spacing="10" Padding="10" HorizontalOptions="Center">
            <Button Text="Редагувати склад" 
                    Command="{Binding EditWarehouseCommand}" 
                    BackgroundColor="#2196F3" />
            <Button Text="Видалити склад" 
                    Command="{Binding DeleteWarehouseCommand}" 
                    BackgroundColor="Red" />
        </HorizontalStackLayout>

        <SearchBar Grid.Row="2"
                   Placeholder="Пошук товарів..."
                   Text="{Binding SearchText}"
                   SearchCommand="{Binding ApplyFilterAndSortCommand}">
            <SearchBar.Behaviors>
                <mct:EventToCommandBehavior EventName="TextChanged" 
                                            Command="{Binding ApplyFilterAndSortCommand}" />
            </SearchBar.Behaviors>
        </SearchBar>

        <HorizontalStackLayout Grid.Row="3" Spacing="10" Padding="10">
            <Label Text="Сортувати за:" VerticalOptions="Center" />
            <Picker ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSortOption}"
                    WidthRequest="150">
                <Picker.Behaviors>
                    <mct:EventToCommandBehavior EventName="SelectedIndexChanged" 
                                                Command="{Binding ApplyFilterAndSortCommand}" />
                </Picker.Behaviors>
            </Picker>
        </HorizontalStackLayout>

        <RefreshView Grid.Row="4"
                     Command="{Binding RefreshDataCommand}">
            <CollectionView ItemsSource="{Binding Goods}"
                            Margin="10"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:GoodListDTO">
                        <Border Stroke="Magenta" 
                                Padding="10" 
                                Margin="0,5">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WarehouseDetailsViewModel}}, Path=LoadGoodCommand}"
                                    CommandParameter="{Binding Id}" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout>
                                <Label Text="{Binding Title}" 
                                       FontSize="18" 
                                       FontAttributes="Bold" />

                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="{Binding Price, StringFormat='{0} грн'}" 
                                           TextColor="#2196F3" 
                                           FontAttributes="Bold"/>
                                    <Label Text="{Binding ItemCategory}" 
                                           TextColor="Gray" />
                                    <Label Text="{Binding Quantity, StringFormat='К-сть: {0}'}" 
                                           TextColor="Gray" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="5"
              BackgroundColor="#80000000"
              IsVisible="{Binding IsBusy}">
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   Color="Magenta"
                                   HeightRequest="50"
                                   WidthRequest="50" />
                <Label Text="Завантаження..."
                       TextColor="White"
                       FontSize="18"
                       FontAttributes="Bold" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
