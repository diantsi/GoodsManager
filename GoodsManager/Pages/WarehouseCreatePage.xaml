<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GoodsManager.ViewModels"
             xmlns:mct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="GoodsManager.Pages.WarehouseCreatePage"
             x:DataType="vm:WarehouseCreateViewModel"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <mct:IsStringNotNullOrWhiteSpaceConverter x:Key="IsStringNotNullOrWhiteSpaceConverter" />
    </ContentPage.Resources>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="15">
                
                <Label Text="Назва складу" FontAttributes="Bold" />
                <Entry Text="{Binding Name}" Placeholder="Введіть назву..." />
                <Label Text="{Binding Errors[Name]}" 
                       TextColor="Red" 
                       FontSize="Small"
                       IsVisible="{Binding Errors[Name], Converter={StaticResource IsStringNotNullOrWhiteSpaceConverter}}" />

                <Label Text="Місто" FontAttributes="Bold" />
                <Picker ItemsSource="{Binding Cities}"
                        SelectedItem="{Binding SelectedCity}" />

                <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,20,0,0">
                    <Button Grid.Column="0" 
                            Text="{Binding SubmitButtonText}" 
                            Command="{Binding SaveCommand}" 
                            BackgroundColor="#2196F3" />
                    <Button Grid.Column="1" 
                            Text="Скасувати" 
                            Command="{Binding CancelCommand}" 
                            BackgroundColor="Gray" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <BoxView IsVisible="{Binding IsBusy}"
                 BackgroundColor="Gray"
                 Opacity="0.3"
                 InputTransparent="False" />
        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Color="#2196F3" />
    </Grid>
</ContentPage>
